## Backend env example (copy to `server/.env`)
PORT=5000

## Choose a database provider:
## - sqlite (local file)
## - postgres (Supabase Postgres)
DB_PROVIDER=postgres

## Supabase Postgres connection string (Dashboard -> Project Settings -> Database -> Connection string)
## Prefer the "pooler" hostname if your network can't reach `db.<project-ref>.supabase.co`.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@<DB_HOST>:5432/postgres

## Supabase Auth issuer/JWKS (backend verifies Supabase JWTs)
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# SUPABASE_JWT_ISSUER=https://<PROJECT_REF>.supabase.co/auth/v1

## Optional: used only for SQLite "legacy auth" (not used when DB_PROVIDER=postgres)
JWT_SECRET=change_me

## Optional: local sqlite filename
# SQLITE_FILENAME=./database/mindfullcare.db

## Optional: allow server to boot even if DB is down (API returns 503 until DB is ready)
# SKIP_DB=true
# DB_CONNECT_OPTIONAL=true

## Optional: create/update an admin in SQLite mode
# ADMIN_NAME=Admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me
